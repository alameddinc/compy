{
  "manifest_version": 3,
  "name": "Compy — Your memory & your AI's",
  "version": "1.1.0",
  "description": "Highlight & note anything on the web, then hand your AI a versioned task list. Made for vibecoders shipping fast. Local & private.",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Compy",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/store.js",
        "content/anchor.js",
        "content/highlighter.js",
        "content/annotate.js",
        "content/content.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "commands": {
    "highlight-selection": {
      "suggested_key": { "default": "Alt+Shift+H", "mac": "Alt+Shift+H" },
      "description": "Highlight current selection"
    },
    "highlight-with-note": {
      "suggested_key": { "default": "Alt+Shift+N", "mac": "Alt+Shift+N" },
      "description": "Highlight selection and add a note"
    },
    "open-dashboard": {
      "suggested_key": { "default": "Alt+Shift+D", "mac": "Alt+Shift+D" },
      "description": "Open the notes dashboard"
    },
    "add-page-note": {
      "suggested_key": { "default": "Alt+Shift+M", "mac": "Alt+Shift+M" },
      "description": "Add a page note (no highlight)"
    },
    "capture-screenshot": {
      "description": "Screenshot the page & annotate it"
    },
    "_execute_action": {
      "description": "Open the Compy popup (or click the toolbar icon)"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["dashboard/dashboard.html", "demo/demo.html", "demo/seed.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
